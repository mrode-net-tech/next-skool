{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": "src",
    "skipLibCheck": true,
    "types": ["node"],
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@app": ["./src/app"],
      "@middleware/*": ["./src/middleware/*"],
      "@tasks/*": ["./src/tasks/*"]
    }
  },
  "include": ["src/**/*"]
}
