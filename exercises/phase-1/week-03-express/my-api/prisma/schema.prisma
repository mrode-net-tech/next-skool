generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  done        Boolean  @default(false)
  priority    Int      @default(2)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([done])
  @@map("tasks")
}
